; MajestyCredentialProvider.def
; Exports for the COM in-process server DLL.
; These four functions are mandatory for regsvr32 to work.
; Without this file, the linker will not export them by name
; and regsvr32 will fail with "The module was loaded but the
; entry-point DllRegisterServer was not found."

LIBRARY "MajestyGuard.CredentialProvider"

EXPORTS
    DllGetClassObject   PRIVATE
    DllCanUnloadNow     PRIVATE
    DllRegisterServer   PRIVATE
    DllUnregisterServer PRIVATE
