; MajestyCredentialProvider.def
; Exports for the COM in-process server DLL.
; LIBRARY statement removed — it conflicts with the linker's own /OUT
; directive and causes LNK4070. The DLL name is controlled by the
; vcxproj TargetName/OutDir settings, not this file.

EXPORTS
    DllGetClassObject   PRIVATE
    DllCanUnloadNow     PRIVATE
    DllRegisterServer   PRIVATE
    DllUnregisterServer PRIVATE
