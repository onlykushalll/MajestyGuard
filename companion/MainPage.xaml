<Page
    x:Class="MajestyGuard.Companion.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MajestyGuard.Companion"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="40,32,40,32" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <FontIcon Glyph="&#xE8D4;" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            <TextBlock Text="MajestyGuard Companion"
                       Style="{StaticResource TitleTextBlockStyle}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Status card -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="20,16"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0"
                          x:Name="StatusIcon"
                          Glyph="&#xEA3A;"
                          FontSize="32"
                          Foreground="Gray"
                          VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                    <TextBlock x:Name="StatusTitle"
                               Text="Not Registered"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock x:Name="StatusDetail"
                               Text="Register this device to enable face-unlock via Windows Hello."
                               TextWrapping="Wrap"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Opacity="0.7"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Info card -->
        <Border Grid.Row="4"
                Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                CornerRadius="6"
                Padding="16,12"
                BorderBrush="{ThemeResource SystemFillColorNeutralBrush}"
                BorderThickness="1">
            <StackPanel Spacing="6">
                <TextBlock Text="How it works"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.8">
                    <Run>1. </Run><Run FontWeight="SemiBold">Register</Run>
                    <Run> — pairs this app with Windows Hello as a Companion Device.</Run>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.8">
                    <Run>2. </Run><Run FontWeight="SemiBold">Keep daemon running</Run>
                    <Run> — the MajestyGuard Python daemon monitors your face.</Run>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.8">
                    <Run>3. </Run><Run FontWeight="SemiBold">Auto-unlock</Run>
                    <Run> — when your face passes the 12-layer liveness check, your PC unlocks. No password stored.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Progress ring -->
        <ProgressRing Grid.Row="6"
                      x:Name="OpProgress"
                      IsActive="False"
                      Visibility="Collapsed"
                      Width="28" Height="28"
                      HorizontalAlignment="Left"/>

        <!-- Message bar -->
        <InfoBar Grid.Row="6"
                 x:Name="MessageBar"
                 IsOpen="False"
                 IsClosable="True"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="12">
            <Button x:Name="UnregisterButton"
                    Content="Unregister"
                    IsEnabled="False"
                    Click="OnUnregisterClick"
                    Style="{StaticResource DefaultButtonStyle}"/>
            <Button x:Name="RegisterButton"
                    Content="Register Device"
                    Click="OnRegisterClick"
                    Style="{StaticResource AccentButtonStyle}"/>
        </StackPanel>
    </Grid>
</Page>
