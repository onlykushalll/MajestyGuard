<!-- MajestyGuard.Overlay/EnrollmentWindow.xaml
     First-run enrollment wizard.
     Shown when no face data exists for this profile.
     Dark aesthetic matching the Dynamic Island overlay.

     STEPS:
       0 — Welcome
       1 — Camera check (live preview)
       2 — Capture Front
       3 — Capture Slight Left
       4 — Capture Slight Right
       5 — (Optional) Capture with glasses
       6 — Complete / Save

     SIZE: 680 × 500 px, fixed, centered on primary monitor
-->
<Window
    x:Class="MajestyGuard.Overlay.EnrollmentWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MajestyGuard.Overlay"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    Title="Majesty Guard — Face Enrollment">

    <Grid x:Name="MainGrid" Background="#0D0D0F">

        <!-- ── LEFT PANEL: progress rail ──────────────────────────── -->
        <Border
            Width="188"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch"
            Background="#111214"
            BorderBrush="#1E1E22"
            BorderThickness="0,0,1,0">

            <StackPanel
                VerticalAlignment="Center"
                Margin="28,0,20,0"
                Spacing="0">

                <!-- Logo / wordmark -->
                <StackPanel Orientation="Horizontal" Spacing="9" Margin="0,0,0,44">
                    <Ellipse Width="8" Height="8" Fill="#0A84FF" VerticalAlignment="Center"/>
                    <TextBlock
                        Text="MAJESTY GUARD"
                        Foreground="#AAFFFFFF"
                        FontFamily="Segoe UI Variable Display"
                        FontSize="10"
                        FontWeight="SemiBold"
                        CharacterSpacing="120"
                        VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Step items -->
                <ItemsControl x:Name="StepRail" ItemsSource="{x:Bind Steps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:EnrollStep">
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,28">
                                <!-- Step dot -->
                                <Grid Width="22" Height="22">
                                    <!-- Background circle -->
                                    <Ellipse
                                        x:Name="StepDotBg"
                                        Width="22" Height="22"
                                        Fill="{x:Bind DotFill, Mode=OneWay}"/>
                                    <!-- Checkmark for completed steps -->
                                    <TextBlock
                                        Text="✓"
                                        FontSize="11"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="{x:Bind CheckVisible, Mode=OneWay}"/>
                                    <!-- Step number for non-completed -->
                                    <TextBlock
                                        Text="{x:Bind Number}"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="{x:Bind NumberFore, Mode=OneWay}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="{x:Bind NumberVisible, Mode=OneWay}"/>
                                </Grid>
                                <TextBlock
                                    Text="{x:Bind Label}"
                                    Foreground="{x:Bind LabelFore, Mode=OneWay}"
                                    FontFamily="Segoe UI Variable Text"
                                    FontSize="12.5"
                                    VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ── RIGHT PANEL: active step content ───────────────────── -->
        <Grid Margin="188,0,0,0">

            <!-- STEP 0: WELCOME ────────────────────────────────────── -->
            <StackPanel
                x:Name="StepWelcome"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="16"
                MaxWidth="380"
                Padding="40,0">

                <TextBlock
                    Text="Set up face recognition"
                    Foreground="#FFFFFFFF"
                    FontFamily="Segoe UI Variable Display"
                    FontSize="24"
                    FontWeight="SemiBold"
                    TextWrapping="Wrap"/>
                <TextBlock
                    Text="Majesty Guard uses your face to lock and unlock your PC — no password needed. Your face data never leaves this device."
                    Foreground="#88FFFFFF"
                    FontFamily="Segoe UI Variable Text"
                    FontSize="13.5"
                    TextWrapping="Wrap"
                    LineHeight="22"/>

                <Border
                    Background="#0D1A2E"
                    CornerRadius="10"
                    Padding="16,12"
                    Margin="0,8,0,0"
                    BorderBrush="#1E3A5F"
                    BorderThickness="1">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🔒" FontSize="14"/>
                            <TextBlock
                                Text="Stored encrypted on this device only"
                                Foreground="#77AEFF"
                                FontSize="12.5"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="📷" FontSize="14"/>
                            <TextBlock
                                Text="Camera frames are never saved to disk"
                                Foreground="#77AEFF"
                                FontSize="12.5"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🌐" FontSize="14"/>
                            <TextBlock
                                Text="No internet connection required"
                                Foreground="#77AEFF"
                                FontSize="12.5"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Button
                    x:Name="BtnGetStarted"
                    Content="Get started →"
                    Click="BtnGetStarted_Click"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Left"
                    Padding="20,10"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#0A84FF"
                    Foreground="White"
                    CornerRadius="8"/>
            </StackPanel>

            <!-- STEP 1: CAMERA CHECK ────────────────────────────────── -->
            <StackPanel
                x:Name="StepCameraCheck"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="18"
                Visibility="Collapsed"
                Padding="40,0"
                MaxWidth="400">

                <TextBlock
                    Text="Camera check"
                    Foreground="White"
                    FontFamily="Segoe UI Variable Display"
                    FontSize="22"
                    FontWeight="SemiBold"/>
                <TextBlock
                    x:Name="CameraStatusText"
                    Text="Looking for your camera..."
                    Foreground="#88FFFFFF"
                    FontSize="13"/>

                <!-- Live preview container -->
                <Border
                    x:Name="PreviewBorder"
                    Width="220" Height="165"
                    CornerRadius="12"
                    Background="#1A1A1E"
                    BorderBrush="#2A2A30"
                    BorderThickness="1"
                    HorizontalAlignment="Left">
                    <!-- CODEX: Replace inner Image source with live webcam bitmap stream -->
                    <Grid>
                        <Image x:Name="PreviewImage" Stretch="UniformToFill"/>
                        <TextBlock
                            x:Name="NoPreviewText"
                            Text="No camera found"
                            Foreground="#555555"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="12"/>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button
                        x:Name="BtnCameraOk"
                        Content="Camera looks good →"
                        Click="BtnCameraOk_Click"
                        IsEnabled="False"
                        Padding="16,9"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Background="#0A84FF"
                        Foreground="White"
                        CornerRadius="8"/>
                    <Button
                        Content="Try different camera"
                        Click="BtnSwitchCamera_Click"
                        Padding="16,9"
                        FontSize="13"
                        Background="#222228"
                        Foreground="#AAFFFFFF"
                        CornerRadius="8"/>
                </StackPanel>
            </StackPanel>

            <!-- STEPS 2–4: FACE CAPTURE ─────────────────────────────── -->
            <!-- All three capture steps share this layout; content swaps via binding -->
            <Grid
                x:Name="StepCapture"
                Visibility="Collapsed"
                Margin="32,0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="8,36,0,20" Spacing="6">
                    <TextBlock
                        x:Name="CaptureTitle"
                        Text="Look straight ahead"
                        Foreground="White"
                        FontFamily="Segoe UI Variable Display"
                        FontSize="22"
                        FontWeight="SemiBold"/>
                    <TextBlock
                        x:Name="CaptureSubtitle"
                        Text="Hold still — we'll capture automatically when your face is in position."
                        Foreground="#88FFFFFF"
                        FontSize="13"
                        TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Camera + face guide -->
                <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Live preview -->
                    <Border
                        Width="260" Height="195"
                        CornerRadius="16"
                        Background="#1A1A1E"
                        BorderBrush="#222228"
                        BorderThickness="1">
                        <Image x:Name="CapturePreview" Stretch="UniformToFill"/>
                    </Border>

                    <!-- Face oval guide overlay -->
                    <Ellipse
                        x:Name="FaceGuideOval"
                        Width="120" Height="155"
                        StrokeThickness="2"
                        Fill="Transparent">
                        <Ellipse.Stroke>
                            <SolidColorBrush x:Name="OvalStrokeBrush" Color="#440A84FF"/>
                        </Ellipse.Stroke>
                    </Ellipse>

                    <!-- Corner tick marks (top-left, top-right, bottom-left, bottom-right) -->
                    <!-- These pulse green when face is in correct position -->
                    <Canvas Width="260" Height="195">
                        <Line X1="50" Y1="20" X2="50" Y2="32" Stroke="#0A84FF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" x:Name="TickTL_V"/>
                        <Line X1="38" Y1="20" X2="50" Y2="20" Stroke="#0A84FF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" x:Name="TickTL_H"/>
                        <Line X1="210" Y1="20" X2="210" Y2="32" Stroke="#0A84FF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" x:Name="TickTR_V"/>
                        <Line X1="210" Y1="20" X2="222" Y2="20" Stroke="#0A84FF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" x:Name="TickTR_H"/>
                        <Line X1="50" Y1="175" X2="50" Y2="163" Stroke="#0A84FF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" x:Name="TickBL_V"/>
                        <Line X1="38" Y1="175" X2="50" Y2="175" Stroke="#0A84FF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" x:Name="TickBL_H"/>
                        <Line X1="210" Y1="175" X2="210" Y2="163" Stroke="#0A84FF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" x:Name="TickBR_V"/>
                        <Line X1="210" Y1="175" X2="222" Y2="175" Stroke="#0A84FF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" x:Name="TickBR_H"/>
                    </Canvas>

                    <!-- Status badge at bottom of preview -->
                    <Border
                        x:Name="CaptureBadge"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,-18"
                        Padding="14,6"
                        CornerRadius="20"
                        Background="#0D0D0F"
                        BorderBrush="#2A2A30"
                        BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse x:Name="CaptureDot" Width="7" Height="7" Fill="#666666" VerticalAlignment="Center"/>
                            <TextBlock
                                x:Name="CaptureStatusText"
                                Text="Position your face in the oval"
                                Foreground="#88FFFFFF"
                                FontSize="12"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Bottom action row -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="8,36,0,32">
                    <Button
                        x:Name="BtnCapture"
                        Content="Capture now"
                        Click="BtnCapture_Click"
                        IsEnabled="True"
                        Padding="18,10"
                        FontSize="13.5"
                        FontWeight="SemiBold"
                        Background="#0A84FF"
                        Foreground="White"
                        CornerRadius="8"/>
                    <Button
                        x:Name="BtnRetry"
                        Content="Retry"
                        Click="BtnRetry_Click"
                        Visibility="Collapsed"
                        Padding="16,10"
                        FontSize="13.5"
                        Background="#222228"
                        Foreground="#AAFFFFFF"
                        CornerRadius="8"/>
                    <Button
                        x:Name="BtnSkipAngle"
                        Content="Skip optional"
                        Click="BtnSkipAngle_Click"
                        Visibility="Collapsed"
                        Padding="16,10"
                        FontSize="13"
                        Background="#1A1A1E"
                        Foreground="#666666"
                        CornerRadius="8"/>
                </StackPanel>
            </Grid>

            <!-- STEP 5: OPTIONAL GLASSES ─────────────────────────────── -->
            <!-- (same layout as capture steps, shown via StepCapture with different content) -->

            <!-- STEP 6: COMPLETE ────────────────────────────────────── -->
            <StackPanel
                x:Name="StepComplete"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="16"
                MaxWidth="360"
                Padding="40,0"
                Visibility="Collapsed">

                <!-- Success circle -->
                <Border
                    Width="72" Height="72"
                    CornerRadius="36"
                    Background="#0D2A1A"
                    BorderBrush="#1E4A2E"
                    BorderThickness="1"
                    HorizontalAlignment="Center">
                    <TextBlock
                        Text="✓"
                        FontSize="30"
                        FontWeight="Bold"
                        Foreground="#30D158"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>

                <TextBlock
                    Text="You're all set, your majesty"
                    Foreground="White"
                    FontFamily="Segoe UI Variable Display"
                    FontSize="22"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"/>

                <TextBlock
                    x:Name="CompleteSubtitle"
                    Text="Face recognition is now active. Your PC will lock automatically when you step away."
                    Foreground="#88FFFFFF"
                    FontSize="13.5"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    LineHeight="22"/>

                <StackPanel Spacing="10" Margin="0,8,0,0">
                    <Button
                        Content="Start using Majesty Guard"
                        Click="BtnFinish_Click"
                        HorizontalAlignment="Stretch"
                        Padding="0,12"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Background="#0A84FF"
                        Foreground="White"
                        CornerRadius="8"/>
                    <Button
                        Content="Test face recognition"
                        Click="BtnTest_Click"
                        HorizontalAlignment="Stretch"
                        Padding="0,11"
                        FontSize="13.5"
                        Background="#1A1A1E"
                        Foreground="#AAFFFFFF"
                        CornerRadius="8"/>
                </StackPanel>
            </StackPanel>

            <!-- ERROR panel (overlays any step) -->
            <Border
                x:Name="ErrorBanner"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch"
                Margin="32,0,32,28"
                Padding="16,12"
                CornerRadius="10"
                Background="#2A1010"
                BorderBrush="#5A1A1A"
                BorderThickness="1"
                Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="⚠" Foreground="#FF453A" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock
                        x:Name="ErrorText"
                        Text=""
                        Foreground="#FF8080"
                        FontSize="12.5"
                        VerticalAlignment="Center"
                        TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </Grid>

        <!-- Resources -->
        <Grid.Resources>
            <Storyboard x:Key="OvalPulseReady">
                <ColorAnimation
                    Storyboard.TargetName="OvalStrokeBrush"
                    Storyboard.TargetProperty="Color"
                    To="#CC30D158" Duration="0:0:0.4">
                    <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                </ColorAnimation>
            </Storyboard>
            <Storyboard x:Key="OvalPulseIdle">
                <ColorAnimation
                    Storyboard.TargetName="OvalStrokeBrush"
                    Storyboard.TargetProperty="Color"
                    To="#440A84FF" Duration="0:0:0.3"/>
            </Storyboard>
        </Grid.Resources>
    </Grid>
</Window>
