<!-- MajestyGuard.Overlay/DynamicIslandWindow.xaml -->
<!--
  ═══════════════════════════════════════════════════════════════════
  MAJESTY GUARD — DYNAMIC ISLAND OVERLAY
  ═══════════════════════════════════════════════════════════════════

  DESIGN SYSTEM:
  ┌─────────────────────────────────────────────────────────────┐
  │  Colors                                                     │
  │  ─────────────────────────────────────────────────────────  │
  │  Pill background:   #111214  (near-black, not pure black)  │
  │  Pill gradient top: #16181A                                 │
  │  Pill border:       #2A2A2A  (subtle 1px border)           │
  │  Text primary:      #FFFFFF                                 │
  │  Text secondary:    #888888                                 │
  │  Accent scanning:   #0A84FF  (Apple system blue)           │
  │  Accent verified:   #30D158  (Apple system green)          │
  │  Accent social:     #FF9F0A  (Apple system amber)          │
  │  Accent hostile:    #FF453A  (Apple system red)            │
  │                                                             │
  │  Pill Dimensions (per state)                                │
  │  ─────────────────────────────────────────────────────────  │
  │  Searching:    296 x 38px,  r=19                           │
  │  Verifying:    344 x 56px,  r=28                           │
  │  SocialLock:   100vw x 46px, r=0                           │
  │  Lock:         300 x 44px,  r=22                           │
  └─────────────────────────────────────────────────────────────┘

  LAYERS (bottom → top):
    1. BlackOverlay   HostileLock/InactivityLock opaque cover
    2. BlurCanvas     Win2D Gaussian blur of desktop
    3. FrostOverlay   WinUI Acrylic for SocialLock
    4. VignetteRect   Radial edge-darkening during verification
    5. ScanRings      Rotating arcs behind pill (Verifying state)
    6. IslandPill     The main pill element (top of z-order)

  CODEX IMPLEMENTS:
    → Win2D GaussianBlurEffect in BlurCanvas_Draw()
    → All Storyboard Begin() calls from ApplyState()
    → Width/Height animations on IslandPill
    → WGC desktop capture (Windows.Graphics.Capture API)
    → ScanRing continuous rotation

  SCAFFOLD DEFINES (complete):
    → Full visual structure and hierarchy ✓
    → Color system and typography ✓
    → All animation definitions with easing ✓
    → All state content panels ✓
-->

<Window
    x:Class="MajestyGuard.Overlay.DynamicIslandWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    Title="MajestyGuard.Overlay">

    <Window.SystemBackdrop>
        <TransparentBackdrop/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="Transparent">

        <!-- LAYER 1: BLACK OVERLAY ───────────────────────────────── -->
        <Rectangle
            x:Name="BlackOverlay"
            Fill="#FF000000"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Opacity="0"/>

        <!-- LAYER 2: BLUR CANVAS ─────────────────────────────────── -->
        <canvas:CanvasControl
            x:Name="BlurCanvas"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Opacity="0"
            Draw="BlurCanvas_Draw"/>

        <!-- LAYER 3: FROSTED GLASS (SocialLock) ─────────────────── -->
        <Rectangle
            x:Name="FrostOverlay"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Opacity="0">
            <Rectangle.Fill>
                <media:AcrylicBrush
                    TintColor="#0D0D0D"
                    TintOpacity="0.55"
                    TintLuminosityOpacity="0.65"
                    FallbackColor="#CC0D0D0D"/>
            </Rectangle.Fill>
        </Rectangle>

        <!-- LAYER 4: EDGE VIGNETTE ───────────────────────────────── -->
        <Rectangle
            x:Name="VignetteRect"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Opacity="0"
            IsHitTestVisible="False">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.72" RadiusY="0.72" GradientOrigin="0.5,0.5">
                    <GradientStop Color="Transparent" Offset="0.35"/>
                    <GradientStop Color="#99000000"   Offset="1.0"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- LAYER 5: FACE SCAN RINGS (Verifying) ─────────────────── -->
        <Ellipse
            x:Name="ScanRingOuter"
            Width="480" Height="480"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0"
            StrokeThickness="1.2"
            Fill="Transparent">
            <Ellipse.Stroke>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#110A84FF" Offset="0.0"/>
                    <GradientStop Color="#880A84FF" Offset="0.5"/>
                    <GradientStop Color="#110A84FF" Offset="1.0"/>
                </LinearGradientBrush>
            </Ellipse.Stroke>
            <Ellipse.RenderTransformOrigin>0.5,0.5</Ellipse.RenderTransformOrigin>
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="ScanRingRotate" Angle="0"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <Ellipse
            x:Name="ScanRingInner"
            Width="340" Height="340"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0"
            StrokeThickness="0.6"
            Stroke="#330A84FF"
            Fill="Transparent">
            <Ellipse.RenderTransformOrigin>0.5,0.5</Ellipse.RenderTransformOrigin>
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="ScanRingInnerRotate" Angle="0"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- LAYER 6: THE DYNAMIC ISLAND PILL ─────────────────────── -->
        <Border
            x:Name="IslandPill"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,16,0,0"
            Width="380"
            Height="46"
            CornerRadius="23"
            Opacity="0"
            BorderThickness="1">

            <Border.RenderTransformOrigin>0.5,0.0</Border.RenderTransformOrigin>
            <Border.RenderTransform>
                <ScaleTransform x:Name="PillScale" ScaleX="0.85" ScaleY="0.85"/>
            </Border.RenderTransform>

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#16181A" Offset="0.0"/>
                    <GradientStop Color="#0E1012" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2E2E2E" Offset="0.0"/>
                    <GradientStop Color="#1A1A1A" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid>
                <!-- Glow border overlay (color changes per state) -->
                <Border
                    x:Name="PillGlowBorder"
                    CornerRadius="23"
                    BorderThickness="1.5"
                    Opacity="0">
                    <Border.BorderBrush>
                        <SolidColorBrush x:Name="GlowBrush" Color="#0A84FF"/>
                    </Border.BorderBrush>
                </Border>

                <!-- Content host -->
                <Grid Padding="16,0,16,0">

                    <!-- SEARCHING ─────────────────────────────────── -->
                    <StackPanel
                        x:Name="SearchingContent"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Opacity="0"
                        Visibility="Collapsed">
                        <Ellipse
                            x:Name="CameraDot"
                            Width="7" Height="7"
                            VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="#0A84FF"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock
                            Text="Scanning..."
                            Foreground="#CCFFFFFF"
                            FontFamily="Segoe UI Variable Display"
                            FontSize="14"
                            FontWeight="Medium"
                            VerticalAlignment="Center"
                            CharacterSpacing="10"/>
                    </StackPanel>

                    <!-- VERIFYING: Apple Dynamic Island FaceID morphed square ─── -->
                    <!-- Pill animates to ~106x106 rounded square (set in code-behind) -->
                    <!-- This Grid fills the square pill and shows the face-scan icon  -->
                    <Grid
                        x:Name="VerifyingContent"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="70"
                        Height="70"
                        Opacity="0"
                        Visibility="Collapsed">

                        <!-- ── Face ID Icon: four corner brackets + face features ── -->
                        <!-- Matches Apple's FaceID icon as closely as XAML allows   -->
                        <Canvas Width="70" Height="70">

                            <!-- Corner brackets: 12px arms, 4px gap from edges -->
                            <!-- Top-left bracket -->
                            <Path Stroke="#DDFFFFFF" StrokeThickness="2.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Data="M4,18 L4,6 Q4,4 6,4 L18,4"/>
                            <!-- Top-right bracket -->
                            <Path Stroke="#DDFFFFFF" StrokeThickness="2.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Data="M66,18 L66,6 Q66,4 64,4 L52,4"/>
                            <!-- Bottom-left bracket -->
                            <Path Stroke="#DDFFFFFF" StrokeThickness="2.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Data="M4,52 L4,64 Q4,66 6,66 L18,66"/>
                            <!-- Bottom-right bracket -->
                            <Path Stroke="#DDFFFFFF" StrokeThickness="2.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Data="M66,52 L66,64 Q66,66 64,66 L52,66"/>

                            <!-- Left eye: short horizontal dash -->
                            <Rectangle Canvas.Left="19" Canvas.Top="24"
                                       Width="9" Height="3.5"
                                       Fill="#FFFFFFFF" RadiusX="1.75" RadiusY="1.75"/>
                            <!-- Right eye: short horizontal dash -->
                            <Rectangle Canvas.Left="42" Canvas.Top="24"
                                       Width="9" Height="3.5"
                                       Fill="#FFFFFFFF" RadiusX="1.75" RadiusY="1.75"/>

                            <!-- Nose: short vertical line curving slightly -->
                            <Path Stroke="#DDFFFFFF" StrokeThickness="2.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Data="M35,30 L35,38 Q32,41 34,43"/>

                            <!-- Mouth: gentle arc -->
                            <Path Stroke="#DDFFFFFF" StrokeThickness="2.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Data="M24,50 Q35,56 46,50"/>

                        </Canvas>

                        <!-- Scan line: sweeps top→bottom via TranslateTransform.Y -->
                        <Rectangle
                            x:Name="ScanLine"
                            Height="1.5"
                            Width="54"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,4,0,0"
                            Opacity="0">
                            <Rectangle.RenderTransform>
                                <TranslateTransform x:Name="ScanLineTranslate" X="0" Y="0"/>
                            </Rectangle.RenderTransform>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0.0"/>
                                    <GradientStop Color="#AA0A84FF"   Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Grid>

                    <!-- SOCIAL LOCK ────────────────────────────────── -->
                    <StackPanel
                        x:Name="SocialLockContent"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Opacity="0"
                        Visibility="Collapsed">
                        <Ellipse Width="6" Height="6" Fill="#FF9F0A" VerticalAlignment="Center"/>
                        <TextBlock
                            Text="Privacy mode"
                            Foreground="#FF9F0A"
                            FontFamily="Segoe UI Variable Display"
                            FontSize="14"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center"/>
                        <TextBlock Text="·" Foreground="#444444" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock
                            Text="Additional presence detected"
                            Foreground="#AAFFFFFF"
                            FontFamily="Segoe UI Variable Text"
                            FontSize="12.5"
                            VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- LOCK (HostileLock / InactivityLock) ─────────── -->
                    <StackPanel
                        x:Name="LockContent"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="11"
                        Opacity="0"
                        Visibility="Collapsed">
                        <TextBlock
                            Text="&#xE72E;"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="13"
                            Foreground="#555555"
                            VerticalAlignment="Center"/>
                        <StackPanel Orientation="Vertical" Spacing="1" VerticalAlignment="Center">
                            <TextBlock
                                Text="Verify identity"
                                Foreground="#FFFFFFFF"
                                FontFamily="Segoe UI Variable Display"
                                FontSize="13"
                                FontWeight="SemiBold"/>
                            <TextBlock
                                Text="your majesty"
                                Foreground="#505050"
                                FontFamily="Segoe UI Variable Text"
                                FontSize="10.5"
                                FontStyle="Italic"/>
                        </StackPanel>
                    </StackPanel>

                </Grid>
            </Grid>
        </Border>



        <!-- ── FLOATING CAPTION: shown below pill during Verifying ──── -->
        <!-- Positioned independently — floats ~8px below the square pill -->
        <TextBlock
            x:Name="FloatingCaption"
            Text="your majesty"
            Foreground="#55FFFFFF"
            FontFamily="Segoe UI Variable Text"
            FontSize="12"
            FontStyle="Italic"
            FontWeight="Light"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,138,0,0"
            Opacity="0"
            IsHitTestVisible="False"
            CharacterSpacing="40"/>

        <!-- ══════════════════════════════════════════════════════════
             STORYBOARD ANIMATIONS
             CODEX: Call Begin() on each from ApplyState() in code-behind.
        ════════════════════════════════════════════════════════════ -->
        <Grid.Resources>

            <!-- Pill spring appear -->
            <Storyboard x:Key="PillAppear">
                <DoubleAnimation Storyboard.TargetName="IslandPill" Storyboard.TargetProperty="Opacity"
                    From="0" To="1" Duration="0:0:0.20">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PillScale" Storyboard.TargetProperty="ScaleX"
                    From="0.80" To="1.0" Duration="0:0:0.32">
                    <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.25"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PillScale" Storyboard.TargetProperty="ScaleY"
                    From="0.80" To="1.0" Duration="0:0:0.32">
                    <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.25"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Pill collapse out -->
            <Storyboard x:Key="PillDisappear">
                <DoubleAnimation Storyboard.TargetName="IslandPill" Storyboard.TargetProperty="Opacity"
                    From="1" To="0" Duration="0:0:0.25">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PillScale" Storyboard.TargetProperty="ScaleY"
                    From="1.0" To="0.4" Duration="0:0:0.25">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Unlock: green glow flash → then PillDisappear -->
            <Storyboard x:Key="UnlockPulse">
                <DoubleAnimation Storyboard.TargetName="PillGlowBorder" Storyboard.TargetProperty="Opacity"
                    From="0" To="1" Duration="0:0:0.12"/>
                <DoubleAnimation Storyboard.TargetName="PillGlowBorder" Storyboard.TargetProperty="Opacity"
                    From="1" To="0" Duration="0:0:0.60" BeginTime="0:0:0.12">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Camera dot pulse (Searching, repeating) -->
            <Storyboard x:Key="CameraDotPulse" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="CameraDot" Storyboard.TargetProperty="Opacity"
                    From="1.0" To="0.15" Duration="0:0:0.85" AutoReverse="True">
                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Blur + vignette fade in -->
            <Storyboard x:Key="BlurFadeIn">
                <DoubleAnimation Storyboard.TargetName="BlurCanvas" Storyboard.TargetProperty="Opacity"
                    From="0" To="1" Duration="0:0:0.45">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="VignetteRect" Storyboard.TargetProperty="Opacity"
                    From="0" To="1" Duration="0:0:0.50"/>
            </Storyboard>

            <!-- Blur + vignette fade out -->
            <Storyboard x:Key="BlurFadeOut">
                <DoubleAnimation Storyboard.TargetName="BlurCanvas" Storyboard.TargetProperty="Opacity"
                    From="1" To="0" Duration="0:0:0.35"/>
                <DoubleAnimation Storyboard.TargetName="VignetteRect" Storyboard.TargetProperty="Opacity"
                    From="1" To="0" Duration="0:0:0.35"/>
            </Storyboard>

            <!-- Black overlay in -->
            <Storyboard x:Key="BlackOverlayIn">
                <DoubleAnimation Storyboard.TargetName="BlackOverlay" Storyboard.TargetProperty="Opacity"
                    From="0" To="1" Duration="0:0:0.50">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Black overlay out -->
            <Storyboard x:Key="BlackOverlayOut">
                <DoubleAnimation Storyboard.TargetName="BlackOverlay" Storyboard.TargetProperty="Opacity"
                    From="1" To="0" Duration="0:0:0.40"/>
            </Storyboard>

            <!-- Frost overlay in (SocialLock) -->
            <Storyboard x:Key="FrostIn">
                <DoubleAnimation Storyboard.TargetName="FrostOverlay" Storyboard.TargetProperty="Opacity"
                    From="0" To="1" Duration="0:0:0.35"/>
            </Storyboard>

            <!-- Frost overlay out -->
            <Storyboard x:Key="FrostOut">
                <DoubleAnimation Storyboard.TargetName="FrostOverlay" Storyboard.TargetProperty="Opacity"
                    From="1" To="0" Duration="0:0:0.40"/>
            </Storyboard>

            <!-- Scan rings appear -->
            <Storyboard x:Key="ScanRingsIn">
                <DoubleAnimation Storyboard.TargetName="ScanRingOuter" Storyboard.TargetProperty="Opacity"
                    From="0" To="1" Duration="0:0:0.50"/>
                <DoubleAnimation Storyboard.TargetName="ScanRingInner" Storyboard.TargetProperty="Opacity"
                    From="0" To="0.6" Duration="0:0:0.50"/>
            </Storyboard>

            <!-- Scan ring continuous rotation (start separately, never stop while Verifying) -->
            <Storyboard x:Key="ScanRingRotation" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="ScanRingRotate" Storyboard.TargetProperty="Angle"
                    From="0" To="360" Duration="0:0:4.5">
                    <DoubleAnimation.EasingFunction><LinearEase/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="ScanRingInnerRotate" Storyboard.TargetProperty="Angle"
                    From="360" To="0" Duration="0:0:7">
                    <DoubleAnimation.EasingFunction><LinearEase/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Scan rings disappear -->
            <Storyboard x:Key="ScanRingsOut">
                <DoubleAnimation Storyboard.TargetName="ScanRingOuter" Storyboard.TargetProperty="Opacity"
                    From="1" To="0" Duration="0:0:0.30"/>
                <DoubleAnimation Storyboard.TargetName="ScanRingInner" Storyboard.TargetProperty="Opacity"
                    From="0.6" To="0" Duration="0:0:0.30"/>
            </Storyboard>


            <!-- ── Scan line sweep (Verifying) ──────────────────────── -->
            <!-- Translates the blue line from top to bottom of the FaceID square -->
            <Storyboard x:Key="ScanLineSweep" RepeatBehavior="Forever">
                <!-- Sweep Y: 0 (top of icon) → 58px (bottom), ease in+out -->
                <DoubleAnimationUsingKeyFrames
                    Storyboard.TargetName="ScanLineTranslate"
                    Storyboard.TargetProperty="Y">
                    <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:1.5"  Value="58">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:1.9"  Value="58"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:2.1"  Value="0"/>
                </DoubleAnimationUsingKeyFrames>
                <!-- Fade in once at start, stays visible while repeating -->
                <DoubleAnimation
                    Storyboard.TargetName="ScanLine"
                    Storyboard.TargetProperty="Opacity"
                    From="0" To="0.85" Duration="0:0:0.35"/>
            </Storyboard>

            <!-- ── Caption fade in (Verifying) ──────────────────────── -->
            <Storyboard x:Key="CaptionFadeIn">
                <DoubleAnimation
                    Storyboard.TargetName="FloatingCaption"
                    Storyboard.TargetProperty="Opacity"
                    From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.25">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- ── Caption fade out ──────────────────────────────────── -->
            <Storyboard x:Key="CaptionFadeOut">
                <DoubleAnimation
                    Storyboard.TargetName="FloatingCaption"
                    Storyboard.TargetProperty="Opacity"
                    From="1" To="0" Duration="0:0:0.2"/>
            </Storyboard>

            <!-- ── FaceID content fade in (delayed for pill morph) ───── -->
            <Storyboard x:Key="FaceIdContentIn">
                <DoubleAnimation
                    Storyboard.TargetName="VerifyingContent"
                    Storyboard.TargetProperty="Opacity"
                    From="0" To="1" Duration="0:0:0.22" BeginTime="0:0:0.18">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>


            <!-- ── Blue glow breathing (Verifying state) ─────────────── -->
            <!-- Subtle opacity pulse on the glow border while FaceID scans -->
            <Storyboard x:Key="PillGlowPulse" RepeatBehavior="Forever">
                <DoubleAnimation
                    Storyboard.TargetName="PillGlowBorder"
                    Storyboard.TargetProperty="Opacity"
                    From="0.0" To="0.7" Duration="0:0:1.1"
                    AutoReverse="True">
                    <DoubleAnimation.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

        </Grid.Resources>

    </Grid>
</Window>
